# ============================================================
# Dauntless Agentic — Client Intelligence Portal
# .env.local.example
#
# Copy to `.env.local` and fill in the values you need.
# Every variable below is optional; the portal boots without
# any of them and falls back to the deterministic in-memory
# seed + dev-bypass identity.
#
# ── PRE-LAUNCH POSTURE (2026-05-13 → ~2026-07-13) ───────────
# We are in stealth until ~2 weeks before client onboarding.
# In the pre-launch window, the ONLY variable worth setting is
# ANTHROPIC_API_KEY (Phase 3+ agents — pays for itself in eval
# coverage and demo fidelity).
#
# Leave the Supabase / OAuth / API-key blocks unset until the
# launch-eve sprint. See docs/pre-launch-plan.md for the
# scheduling and docs/client-portal-roadmap.md for per-phase
# launch-posture tags.
# ============================================================

# ─── Stealth Mode ────────────────────────────────────────────
# Set to "true" to hide all personal identity references (founder name, photo,
# LinkedIn, personal website, BDO/FutureCraft history). Uses anonymous "team"
# copy instead. Flip back to "false" (or remove) when ready to go public.
#
# Build-time variable — must redeploy after changing on Vercel.
NEXT_PUBLIC_STEALTH_MODE=false

# ─── Portal Persistence (Phase 2) — LAUNCH-EVE ──────────────
# When unset, the portal runs against the deterministic in-memory
# repository seeded from lib/portal/mock-data.ts. This is the
# production posture through the stealth window. To wire the
# Supabase / Postgres adapter (Phase 2.1, scheduled for the
# launch-eve sprint — ~2 weeks before client onboarding):
#
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_ANON_KEY=...
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
#
# Or, for a generic Postgres target:
# PORTAL_DATABASE_URL=postgres://user:pass@host:5432/portal

# ─── Portal Identity (Phase 2) — LAUNCH-EVE ─────────────────
# When unset, the portal runs in dev-bypass mode. The TopBar
# role switcher writes a cookie that drives membership-gate
# behaviour. This is the production posture through stealth.
# When you wire real OAuth (Phase 2.1, launch-eve sprint), set:
#
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
# AUTH_SECRET=... # NextAuth session secret; generate with `openssl rand -base64 32`
#
# Optional knobs:
# PORTAL_DEV_BYPASS=true            # Force dev-bypass even when OAuth is configured.
# PORTAL_DEV_BYPASS_MEMBER_ID=u-evance
# PORTAL_ROLE_COOKIE=portal-role    # Override the role-switcher cookie name.

# ─── Portal Agents (Phase 3) — PRE-LAUNCH (recommended) ─────
# When unset, agent panels render against mock conversations
# (no real model calls). Setting this is the one paid
# dependency worth turning on pre-launch — the Phase 3.1
# eval-harness work in docs/pre-launch-plan.md §A1 depends on
# it. To enable the Engagement Analyst against the Anthropic
# API:
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
