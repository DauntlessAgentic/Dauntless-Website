# ============================================================
# Dauntless Agentic — Client Intelligence Portal
# .env.local.example
#
# Copy to `.env.local` and fill in the values you need.
# Local development boots without infrastructure. Production
# requires either real auth or explicit demo mode; do not rely
# on implicit dev-bypass in production.
# ============================================================

# ─── Stealth Mode ────────────────────────────────────────────
# Set to "true" to hide all personal identity references (founder name, photo,
# LinkedIn, personal website, BDO/FutureCraft history). Uses anonymous "team"
# copy instead. Flip back to "false" (or remove) when ready to go public.
#
# Build-time variable — must redeploy after changing on Vercel.
NEXT_PUBLIC_STEALTH_MODE=false

# Public base URL used by examples, metadata, and generated links.
NEXT_PUBLIC_PORTAL_BASE_URL=https://dauntlessagentic.com

# ─── Portal Persistence (Phase 2) ────────────────────────────
# When unset, the portal runs against the deterministic in-memory
# repository seeded from lib/portal/mock-data.ts. To wire the
# Supabase / Postgres adapter (lands in Phase 2.1):
#
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_ANON_KEY=...
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
#
# Or, for a generic Postgres target:
# PORTAL_DATABASE_URL=postgres://user:pass@host:5432/portal

# ─── Portal Identity (Phase 2) ───────────────────────────────
# Local development runs in dev-bypass when OAuth is unset. In production,
# unauthenticated portal access is blocked unless PORTAL_DEMO_MODE=true.
# When you wire real OAuth, set:
#
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
# AUTH_GOOGLE_REDIRECT_URI=https://dauntlessagentic.com/auth/callback
# AUTH_SECRET=... # Generate with `openssl rand -base64 32`
#
# Optional knobs:
# PORTAL_PUBLIC_ENABLED=false      # Keep false/omit for the marketing-only launch. Set true when unveiling /portal.
# PORTAL_DEMO_MODE=true            # Production-only public demo mode with labeled sample data.
# PORTAL_DEV_BYPASS=true           # Local-only role switcher override when OAuth is configured.
# PORTAL_DEV_BYPASS_MEMBER_ID=u-evance
# PORTAL_ROLE_COOKIE=portal-role    # Override the role-switcher cookie name.

# ─── Portal REST API (Phase 9) ────────────────────────────────
# Production should set a bearer token unless this is an explicitly open demo.
#
# PORTAL_API_KEY=replace-with-32-plus-byte-secret
# PORTAL_ALLOW_OPEN_API=false       # Set true only for a deliberate public API demo.
# PORTAL_API_RATE_BURST=30
# PORTAL_API_RATE_REFILL=5

# ─── Evidence Exports ────────────────────────────────────────
# Required for audit-grade exports in production. Previous key is used during
# rotation windows so older bundles can still verify.
#
# PORTAL_EXPORT_SIGNING_KEY=replace-with-32-plus-byte-secret
# PORTAL_EXPORT_SIGNING_KEY_PREVIOUS=

# ─── Portal Agents (Phase 3) ─────────────────────────────────
# When unset, agent panels render against mock conversations
# (no real model calls). To enable the Engagement Analyst
# against the Anthropic API:
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7

# ─── Observability (launch choice required) ───────────────────
# Choose a provider before public launch and add its env vars here.
#
# SENTRY_DSN=
#
