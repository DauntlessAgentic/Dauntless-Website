# ─── Stealth Mode ────────────────────────────────────────────────────────────
# Set to "true" to hide all personal identity references (founder name, photo,
# LinkedIn, personal website, BDO/FutureCraft history). Uses anonymous "team"
# copy instead. Flip back to "false" (or remove) when ready to go public.
#
# This is a build-time variable — you must redeploy after changing it.
# On Vercel: Project Settings → Environment Variables → NEXT_PUBLIC_STEALTH_MODE
#
NEXT_PUBLIC_STEALTH_MODE=false

# ─── Client Intelligence Portal: repository backend ──────────────────────────
# Switches lib/portal/repositories between the mock backend (default) and the
# Supabase backend stub. Stays on "mock" until the Supabase migrations have
# been applied AND the supabase backend in lib/portal/repositories/supabase.ts
# has been wired with real client calls.
#
PORTAL_REPOSITORY_BACKEND=mock

# ─── Supabase (used by the Phase 2+ wire-up) ─────────────────────────────────
# Required only when PORTAL_REPOSITORY_BACKEND=supabase. The portal will run
# against the mock backend with these unset.
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
